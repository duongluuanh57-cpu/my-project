  <script src="/js/i18n.js"></script>
  <script src="/js/theme.js"></script>
  <script>
  // Detect server tắt qua SSE
  (function() {
    var es = new EventSource('/__ping');
    var overlay = null;
    es.onerror = function() {
      es.close();
      if (overlay) return;
      overlay = document.createElement('div');
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:99999;display:flex;align-items:center;justify-content:center;';
      overlay.innerHTML = '<div style="background:#1e293b;color:#f1f5f9;padding:40px 48px;border-radius:16px;text-align:center;max-width:360px">'
        + '<div style="font-size:48px;margin-bottom:16px">🔌</div>'
        + '<h2 style="margin:0 0 8px;font-size:20px">Server đã tắt</h2>'
        + '<p style="color:#94a3b8;margin:0 0 24px;font-size:14px">Mở lại start.bat để khởi động server.</p>'
        + '</div>';
      document.body.appendChild(overlay);
    };
  })();
  </script>
  <script>
  (function () {
    // Sidebar nav-group toggle
    document.querySelectorAll('.nav-group-header').forEach(function (header) {
      var items = header.nextElementSibling;
      // Tự mở nếu có sub-item đang active
      if (items && items.querySelector('.nav-sub-item.active')) {
        header.classList.add('expanded');
        items.classList.add('open');
      }
      header.addEventListener('click', function () {
        var isOpen = items.classList.contains('open');
        header.classList.toggle('expanded', !isOpen);
        items.classList.toggle('open', !isOpen);
      });
    });

    // Set active nav item dựa theo URL hiện tại
    var path = window.location.pathname;
    document.querySelectorAll('.nav-sub-item, .nav-item').forEach(function (a) {
      var href = a.getAttribute('href');
      if (href === path || (href !== '/' && path.startsWith(href))) {
        a.classList.add('active');
        // Mở group cha nếu có
        var group = a.closest('.nav-group-items');
        if (group) {
          group.classList.add('open');
          var groupHeader = group.previousElementSibling;
          if (groupHeader) groupHeader.classList.add('expanded');
        }
      }
    });
    // Trang chủ exact match
    if (path === '/') {
      var homeLink = document.querySelector('.nav-sub-item[href="/"]');
      if (homeLink) {
        homeLink.classList.add('active');
        var group = homeLink.closest('.nav-group-items');
        if (group) {
          group.classList.add('open');
          var groupHeader = group.previousElementSibling;
          if (groupHeader) groupHeader.classList.add('expanded');
        }
      }
    }
  })();
  </script>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quên mật khẩu - FinanceApp</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="auth-body">
  <div class="auth-card">
    <div class="auth-logo">
      <i class="fa-solid fa-wallet"></i>
      <span>FinanceApp</span>
    </div>
    <h2>Quên mật khẩu</h2>
    <p class="auth-sub">Nhập email để nhận link đặt lại mật khẩu</p>

    <% if (error) { %>
      <div class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="auth-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
    <% } %>

    <% if (!success) { %>
    <form action="/forgot-password" method="POST">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="example@email.com" required autofocus>
      </div>
      <button type="submit" class="btn-auth">Gửi link đặt lại</button>
    </form>
    <% } %>

    <p class="auth-switch"><a href="/login"><i class="fa-solid fa-arrow-left"></i> Quay lại đăng nhập</a></p>
  </div>
</body>
</html>

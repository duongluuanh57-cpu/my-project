<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đặt lại mật khẩu - FinanceApp</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="auth-body">
  <div class="auth-card">
    <div class="auth-logo">
      <i class="fa-solid fa-wallet"></i>
      <span>FinanceApp</span>
    </div>
    <h2>Đặt lại mật khẩu</h2>
    <p class="auth-sub">Nhập mật khẩu mới của bạn</p>

    <% if (error) { %>
      <div class="auth-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
    <% } %>

    <% if (token) { %>
    <form action="/reset-password" method="POST">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="form-group">
        <label>Mật khẩu mới</label>
        <input type="password" name="password" placeholder="••••••••" required minlength="6" autofocus>
      </div>
      <div class="form-group">
        <label>Xác nhận mật khẩu</label>
        <input type="password" name="confirmPassword" placeholder="••••••••" required minlength="6">
      </div>
      <button type="submit" class="btn-auth">Đặt lại mật khẩu</button>
    </form>
    <% } %>

    <p class="auth-switch"><a href="/login"><i class="fa-solid fa-arrow-left"></i> Quay lại đăng nhập</a></p>
  </div>
</body>
</html>
